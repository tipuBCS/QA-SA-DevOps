# =============================================================================
# Room Booker API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running the application.
#
#   cp .env.example .env
#
# DO NOT commit .env to source control — it's already in .gitignore.
# =============================================================================

# --- API ---
# Base URL of the deployed API (used by integration tests)
API_URL=https://<your-api-id>.execute-api.eu-west-2.amazonaws.com/dev/

# --- Database ---
# DynamoDB table name (defaults to "room-booker" if not set)
DB_TABLE_NAME=room-booker-dev

# --- Authentication ---
# Secret used to sign JWT tokens. MUST be changed in production.
JWT_SECRET=dev-secret-change-in-production

# Token expiry in hours (defaults to 1)
JWT_EXPIRY_HOURS=1

# --- AWS ---
# AWS region (defaults to eu-west-2)
AWS_REGION=eu-west-2

# --- Integration Tests ---
# Pre-seeded admin credentials used by integration tests and seed_admin.py
TEST_ADMIN_EMAIL=admin@room-booker.com
TEST_ADMIN_PASSWORD=AdminPass123
